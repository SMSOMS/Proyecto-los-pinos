---
const galleryImages = [
  { id: 1, src: "/images/foto_3.jpeg", alt: "Espacio Finca Los Pinos 1" },
  { id: 2, src: "/images/foto_7.jpeg", alt: "Espacio Finca Los Pinos 2" },
  { id: 3, src: "/images/foto_9.jpeg", alt: "Espacio Finca Los Pinos 3" },
  { id: 4, src: "/images/foto_15.jpeg", alt: "Espacio Finca Los Pinos 4" },
  { id: 5, src: "/images/foto_18.jpeg", alt: "Espacio Finca Los Pinos 5" },
  { id: 6, src: "/images/foto_19.jpeg", alt: "Espacio Finca Los Pinos 6" },
  { id: 7, src: "/images/foto_20.jpeg", alt: "Espacio Finca Los Pinos 7" },
  { id: 8, src: "/images/foto_25.jpeg", alt: "Espacio Finca Los Pinos 8" }
];
---

<section id="galeria" class="py-20 bg-brand-white">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="text-center mb-12">
      <p class="font-accent text-4xl text-brand-secondary mb-2">Inspiración</p>
      <h2 class="font-serif text-4xl font-bold text-brand-primary mb-4">Descubre nuestros espacios</h2>
      <p class="text-brand-gray max-w-2xl mx-auto">Sumérgete en la belleza natural de nuestros jardines y rincones con encanto, diseñados para crear recuerdos inolvidables.</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {galleryImages.map((image) => (
        <button 
          class="group relative aspect-square overflow-hidden bg-brand-crema rounded-lg"
          onclick={`openLightbox('${image.src}')`}
          aria-label={`Ver imagen ampliada ${image.id}`}
        >
          <img 
            src={image.src} 
            alt={image.alt} 
            loading="lazy"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-brand-black/0 group-hover:bg-brand-black/20 transition-colors duration-300 flex items-center justify-center">
            <svg class="w-8 h-8 text-brand-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
            </svg>
          </div>
        </button>
      ))}
    </div>
  </div>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 bg-brand-black/95 hidden flex-col items-center justify-center p-4">
    <button 
      id="close-lightbox" 
      class="absolute top-6 right-6 text-brand-white/70 hover:text-brand-white p-2"
      aria-label="Cerrar imagen"
    >
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <img id="lightbox-img" src="" alt="Imagen ampliada" class="max-w-full max-h-[90vh] object-contain rounded" />
  </div>
</section>

<script>
  window.openLightbox = (src) => {
    const lightbox = document.getElementById('lightbox');
    const img = document.getElementById('lightbox-img');
    if (lightbox && img) {
      img.setAttribute('src', src);
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
  };

  document.getElementById('close-lightbox')?.addEventListener('click', () => {
    const lightbox = document.getElementById('lightbox');
    if (lightbox) {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }
  });

  // Close on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.getElementById('close-lightbox')?.click();
    }
  });
</script>
