---
const year = new Date().getFullYear();
---

<footer class="bg-brand-black text-brand-white py-12">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="text-center md:text-left">
        <h3 class="font-serif text-2xl font-bold mb-2">Finca Los Pinos</h3>
        <p class="text-brand-gray text-sm">LOS PINOS EVENTOS SL - B76311109</p>
      </div>

      <nav class="flex flex-wrap justify-center gap-6 text-sm text-brand-white/80">
        <a href="/aviso-legal" class="hover:text-brand-white transition-colors">Aviso Legal</a>
        <a href="/politica-de-privacidad" class="hover:text-brand-white transition-colors">Política de Privacidad</a>
        <a href="/politica-de-cookies" class="hover:text-brand-white transition-colors">Política de Cookies</a>
      </nav>
    </div>

    <div class="border-t border-brand-white/10 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-brand-gray">
      <p>&copy; {year} Finca Los Pinos. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
