---
const vendors = [
  { category: "Catering", list: "La Vaquita, Vintia, Yanioma, Chef Jose Rojano, Casa Pueblo, Barbacoa Canaria" },
  { category: "Floristería", list: "El Arriate" },
  { category: "Iluminación y Sonido", list: "Grupo Ruido" },
  { category: "Carpas", list: "Tentación, Garcitecnia, Loype, Celebraciones Pg, Tents and Events" },
  { category: "Glitter", list: "Glitter Party" },
  { category: "Hora Loca", list: "Party Animal" }
];
---

<section id="proveedores" class="py-20 bg-brand-white border-t border-brand-crema">
  <div class="container mx-auto px-4 max-w-5xl">
    <div class="text-center mb-16">
      <h2 class="font-serif text-3xl font-bold text-brand-primary mb-4">Proveedores Autorizados</h2>
      <p class="text-brand-gray max-w-2xl mx-auto">Trabajamos exclusivamente con profesionales de confianza que garantizan la máxima calidad para que vuestro evento sea un éxito rotundo.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {vendors.map((vendor) => (
        <div class="bg-brand-crema/30 p-6 rounded-xl text-center group hover:bg-brand-crema/60 transition-colors">
          <h3 class="font-serif font-bold text-brand-black text-xl mb-3 group-hover:text-brand-primary transition-colors">{vendor.category}</h3>
          <p class="text-brand-gray/90 leading-relaxed text-sm">{vendor.list}</p>
        </div>
      ))}
    </div>
  </div>
</section>
