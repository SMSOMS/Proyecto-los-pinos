---

<section class="py-16 md:py-24 bg-brand-crema text-brand-black">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="flex flex-col md:flex-row items-center justify-between gap-12">
      
      <!-- Text Intro -->
      <div class="md:w-1/3 text-center md:text-left">
        <p class="font-accent text-4xl text-brand-primary mb-2">Prestigio</p>
        <h2 class="font-serif text-3xl font-bold mb-4">El espacio más recomendado</h2>
        <p class="text-brand-gray">Más de 370 parejas nos han elegido para celebrar el día más importante de sus vidas.</p>
      </div>

      <!-- Awards & Badges -->
      <div class="md:w-2/3 grid grid-cols-2 sm:grid-cols-4 gap-8 items-center text-center">
        <!-- Bodas.net -->
        <a href="https://www.bodas.net/fincas/finca-los-pinos--e31134" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-2 group">
          <div class="w-20 h-20 rounded-full border border-brand-gold/50 flex items-center justify-center bg-brand-white group-hover:border-brand-primary transition-colors">
            <span class="font-serif text-2xl font-bold text-brand-primary">4.9</span>
          </div>
          <span class="text-sm font-medium">Bodas.net</span>
          <span class="text-xs text-brand-gray">181 opiniones</span>
        </a>

        <!-- Wedding Awards -->
        <div class="flex flex-col items-center gap-2">
          <div class="w-20 h-20 flex items-center justify-center">
            <svg class="w-16 h-16 text-brand-gold" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
            </svg>
          </div>
          <span class="text-sm font-medium text-center leading-tight">7 años consecutivos<br/>Wedding Awards</span>
        </div>

        <!-- Zankyou -->
        <div class="flex flex-col items-center gap-2">
          <div class="h-16 flex items-center justify-center">
            <span class="font-serif italic text-2xl font-bold text-brand-black">Zankyou</span>
          </div>
          <span class="text-sm font-medium">Recomendado</span>
        </div>

        <!-- Health & Safety -->
        <div class="flex flex-col items-center gap-2">
          <div class="w-16 h-16 rounded-full bg-brand-secondary/20 flex items-center justify-center">
            <svg class="w-8 h-8 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <span class="text-sm font-medium text-center leading-tight">Health &<br/>Safety</span>
        </div>
      </div>
    </div>
  </div>
</section>
