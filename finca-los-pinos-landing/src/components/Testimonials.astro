---
const testimonials = [
  {
    name: "María & Alejandro",
    date: "14 de Octubre, 2024",
    text: "Fue el día más feliz de nuestras vidas. El entorno es espectacular y el trato inmejorable. Nuestros invitados quedaron fascinados con los jardines.",
    image: "https://images.unsplash.com/photo-1532712938310-34cb3982ef74?q=80&w=200&auto=format&fit=crop"
  },
  {
    name: "Laura & David",
    date: "2 de Septiembre, 2024",
    text: "Profesionalidad de principio a fin. Nos transmitieron mucha tranquilidad y todo salió perfecto. La Finca Los Pinos tiene una magia especial.",
    image: "https://images.unsplash.com/photo-1546825026-b19bf3fa001b?q=80&w=200&auto=format&fit=crop"
  },
  {
    name: "Cristina & Carlos",
    date: "15 de Junio, 2024",
    text: "Si tuviéramos que casarnos otra vez, no dudaríamos en volver a elegir este lugar. Un espacio precioso, cuidado al milímetro.",
    image: "https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=200&auto=format&fit=crop"
  }
];
---

<section id="opiniones" class="py-24 bg-brand-crema">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="text-center mb-16">
      <p class="font-accent text-4xl text-brand-primary mb-2">Historias</p>
      <h2 class="font-serif text-4xl font-bold text-brand-black mb-4">Lo que dicen nuestras parejas</h2>
      <a href="https://www.bodas.net/fincas/finca-los-pinos--e31134/opiniones" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-brand-primary hover:text-brand-secondary font-medium transition-colors">
        Ver las 181 opiniones en Bodas.net (4.9/5)
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="bg-brand-white p-8 rounded-2xl shadow-sm border border-brand-primary/5 relative">
          <div class="absolute -top-6 left-1/2 -translate-x-1/2">
            <img src={t.image} alt={`Boda de ${t.name}`} class="w-16 h-16 rounded-full object-cover border-4 border-brand-white shadow-md" loading="lazy" />
          </div>
          <div class="mt-8 text-center">
            <div class="flex justify-center text-brand-gold mb-4">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-brand-gray italic mb-6">"{t.text}"</p>
            <h3 class="font-serif font-bold text-brand-black text-lg">{t.name}</h3>
            <p class="text-sm text-brand-gray/80">{t.date}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
