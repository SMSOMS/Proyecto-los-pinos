---
---

<section id="contacto" class="py-0 bg-brand-white relative">
  <div class="flex flex-col md:flex-row min-h-[600px]">
    
    <!-- Info Column (Left) -->
    <div class="md:w-1/2 p-8 sm:p-12 md:p-20 flex flex-col justify-center bg-brand-primary text-brand-white relative overflow-hidden">
      <!-- Grid overlay lines to align with the rest of the site -->
      <div class="absolute inset-y-0 left-0 right-0 z-0 pointer-events-none grid grid-cols-2 px-12 opacity-10">
        <div class="border-l border-brand-white h-full"></div>
        <div class="border-l border-brand-white h-full"></div>
      </div>

      <div class="relative z-10">
        <p class="font-accent text-3xl text-brand-gold mb-2 leading-none">Contacto</p>
        <h2 class="font-serif text-3xl md:text-4xl font-bold mb-8">Ven a conocernos</h2>
        
        <div class="space-y-6">
          <!-- Dirección -->
          <div class="flex items-start gap-4">
            <div class="p-2.5 rounded-full bg-brand-white/10 text-brand-gold shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-base leading-snug">Dirección</p>
              <p class="text-brand-white/80 text-sm mt-1 leading-relaxed">
                Calle Lomo Obrero 21<br/>
                35430 Firgas, Gran Canaria<br/>
                Las Palmas (España)
              </p>
              <p class="text-brand-gold text-xs font-semibold mt-1">A tan solo 20 minutos de Las Palmas de Gran Canaria</p>
            </div>
          </div>

          <!-- Teléfono -->
          <div class="flex items-start gap-4">
            <div class="p-2.5 rounded-full bg-brand-white/10 text-brand-gold shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-base leading-snug">Teléfono comercial</p>
              <a href="tel:+34636418627" class="text-brand-white/80 hover:text-brand-white text-sm transition-colors block mt-1">+34 636 418 627</a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="p-2.5 rounded-full bg-brand-white/10 text-brand-gold shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-base leading-snug">Correo electrónico</p>
              <a href="mailto:info@fincapinos.com" class="text-brand-white/80 hover:text-brand-white text-sm transition-colors block mt-1">info@fincapinos.com</a>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap gap-4 items-center mt-10 pt-6 border-t border-brand-white/10">
          <!-- WhatsApp Direct CTA -->
          <a 
            href="https://wa.me/34636418627?text=Hola!%20Me%20gustar%C3%ADa%20solicitar%20informaci%C3%B3n%20sobre%20la%20Finca%20Los%20Pinos%20para%20celebrar%20mi%20boda." 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3.5 bg-brand-gold hover:bg-brand-gold/90 text-brand-black font-semibold rounded-lg shadow-md transition-all duration-300 text-sm cursor-pointer hover:scale-[1.02]"
          >
            <!-- WhatsApp Custom SVG icon -->
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.733-1.46L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.966C16.59 2.016 14.11 1.006 11.817 1c-5.454 0-9.88 4.379-9.884 9.808-.002 2.03.541 4.021 1.571 5.777l-.982 3.58 3.69-.966c1.554.915 3.093 1.34 4.453 1.34zM17.913 14.67c-.337-.17-1.991-.983-2.3-1.097-.304-.116-.528-.172-.75.166-.221.336-.856 1.082-1.05 1.3-.192.22-.386.247-.722.077-.336-.171-1.42-.524-2.707-1.671-1.003-.893-1.68-2.001-1.877-2.338-.197-.337-.021-.52.15-.69.154-.153.338-.396.506-.593.167-.197.222-.337.336-.563.114-.225.056-.42-.028-.592-.084-.17-.75-1.808-1.028-2.476-.27-.652-.544-.564-.75-.575-.192-.01-.413-.012-.633-.012-.22 0-.58.082-.884.417-.305.337-1.164 1.14-1.164 2.784 0 1.644 1.196 3.23 1.36 3.456.163.224 2.353 3.593 5.698 5.037.796.344 1.417.55 1.9.707.8.254 1.528.218 2.103.132.64-.096 1.992-.815 2.274-1.601.283-.787.283-1.46.197-1.602-.085-.14-.313-.227-.65-.397z"/>
            </svg>
            <span>Preguntar por WhatsApp</span>
          </a>

          <!-- Social links -->
          <div class="flex gap-3">
            <a 
              href="https://www.instagram.com/finca_los_pinos/" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="p-3 border border-brand-white/20 rounded-full hover:bg-brand-white hover:text-brand-primary hover:border-brand-white transition-all duration-300"
              aria-label="Instagram"
            >
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a 
              href="https://www.facebook.com/efincapinos/" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="p-3 border border-brand-white/20 rounded-full hover:bg-brand-white hover:text-brand-primary hover:border-brand-white transition-all duration-300"
              aria-label="Facebook"
            >
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Map Column (Right) -->
    <div class="md:w-1/2 h-[350px] md:h-auto bg-brand-crema/50 relative">
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3519.866580977461!2d-15.568393584931326!3d28.106566282628464!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xc4091993f4e240b%3A0xe3497d34199c0dc1!2sFinca%20Los%20Pinos!5e0!3m2!1ses!2ses!4v1620000000000!5m2!1ses!2ses" 
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade"
        title="Mapa de ubicación Finca Los Pinos"
        class="absolute inset-0 w-full h-full"
      ></iframe>
    </div>
  </div>
</section>

