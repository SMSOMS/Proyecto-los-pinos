---
const extras = [
  { name: "Sillas Tiffany champagne", price: "2 €", unit: "unidad" },
  { name: "Parasoles 3x3 m", price: "25 €", unit: "unidad" },
  { name: "Estufas de calor", price: "60 €", unit: "unidad" },
  { name: "Personal limpieza baños", price: "25 €", unit: "persona/hora" },
  { name: "Habitaciones Deluxe", price: "180 €", unit: "noche (IGIC incluido)" },
  { name: "Suite Los Pinos", price: "200 €", unit: "noche (IGIC incluido)" }
];
---

<section id="extras" class="py-20 bg-brand-white">
  <div class="container mx-auto px-4 max-w-5xl">
    <div class="text-center mb-16">
      <h2 class="font-serif text-3xl font-bold text-brand-primary mb-4">Extras y Servicios Adicionales</h2>
      <p class="text-brand-gray">Personaliza tu evento con nuestras opciones adicionales</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6 max-w-4xl mx-auto">
      {extras.map((extra) => (
        <div class="flex items-center justify-between p-4 border-b border-brand-crema hover:bg-brand-crema/30 transition-colors">
          <span class="font-medium text-brand-black">{extra.name}</span>
          <div class="text-right">
            <span class="font-bold text-brand-primary block">{extra.price}</span>
            <span class="text-xs text-brand-gray">/ {extra.unit}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 bg-brand-secondary/10 border border-brand-secondary/30 rounded-lg p-6 text-center max-w-3xl mx-auto flex items-start gap-4 justify-center">
      <svg class="w-6 h-6 text-brand-secondary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p class="text-brand-black/80 font-medium">
        Normativa importante: <span class="font-normal text-brand-gray">No está permitida la pirotecnia, el arroz ni el confeti. Sí se permite el uso de pétalos y productos biodegradables.</span>
      </p>
    </div>
  </div>
</section>
